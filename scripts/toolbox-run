#!/usr/bin/env bash

tool="${0##*/}"
toolbox_dir="$HOME/toolbox"
shellenv=""

if [ "$tool" = "toolbox-run" ]; then
    echo "usage: link this script with the target tool name" >&2
    exit 1
fi

shellenv="$(devbox shellenv --config "$toolbox_dir" --quiet)" || exit 1
eval "$shellenv"
exec "$tool" "$@"
