#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AI_DIR="$ROOT_DIR/ai"
SKILLS_DIR="$AI_DIR/skills"

install_ai_instructions() {
    local tool_file="$1"
    local target="$2"
    local target_dir
    local tmp_file

    target_dir="$(dirname "$target")"
    mkdir -p "$target_dir"

    tmp_file="$(mktemp "${target}.tmp.XXXXXX")"
    {
        cat "$AI_DIR/instructions.md"
        printf '\n\n'
        cat "$AI_DIR/$tool_file"
    } > "$tmp_file"

    mv "$tmp_file" "$target"
}

install_ai_skills() {
    local target="$1"
    local marker
    local skill
    local skill_name
    local tmp_marker

    [ -d "$SKILLS_DIR" ] || return 0

    marker="$target/.dotfiles-managed"

    mkdir -p "$target"

    if [ -f "$marker" ]; then
        while IFS= read -r skill_name; do
            [ -n "$skill_name" ] || continue
            rm -rf "$target/$skill_name"
        done < "$marker"
    fi

    tmp_marker="$(mktemp "${marker}.tmp.XXXXXX")"
    for skill in "$SKILLS_DIR"/*; do
        [ -d "$skill" ] || continue
        skill_name="$(basename "$skill")"
        rm -rf "$target/$skill_name"
        cp -R "$skill" "$target/$skill_name"
        printf '%s\n' "$skill_name" >> "$tmp_marker"
    done

    mv "$tmp_marker" "$marker"
}

install_ai_instructions codex.md "$HOME/.codex/AGENTS.md"
install_ai_instructions claude.md "$HOME/.claude/CLAUDE.md"
install_ai_skills "$HOME/.codex/skills"
install_ai_skills "$HOME/.claude/skills"

echo "Installed Codex instructions to $HOME/.codex/AGENTS.md"
echo "Installed Claude instructions to $HOME/.claude/CLAUDE.md"
echo "Installed shared AI skills to $HOME/.codex/skills and $HOME/.claude/skills"
