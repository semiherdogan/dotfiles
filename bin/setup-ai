#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AI_DIR="$ROOT_DIR/ai"
SKILLS_DIR="$AI_DIR/skills"
LOCAL_SKILLS_DIR="$AI_DIR/skills-local"
FORCE=0
ONLY=""
ONLY_SET=0

usage() {
    cat <<EOF
Usage: setup-ai [--force] [--only codex,claude,pi]

Installs AI instructions and skills for agent directories that already exist.

Options:
  --force, -f  Create missing agent directories before installing.
  --only LIST  Install only selected agents: codex, claude, pi.
  --help, -h   Show this help.
EOF
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --force | -f)
            FORCE=1
            ;;
        --only)
            if [ "$#" -lt 2 ]; then
                echo "--only requires a comma-separated list." >&2
                usage >&2
                exit 1
            fi
            ONLY="$2"
            ONLY_SET=1
            shift
            ;;
        --only=*)
            ONLY="${1#--only=}"
            ONLY_SET=1
            ;;
        --help | -h)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

is_selected() {
    local agent="$1"
    local item
    local old_ifs

    [ "$ONLY_SET" -eq 1 ] || return 0

    if [ -z "$ONLY" ]; then
        echo "--only requires a comma-separated list." >&2
        usage >&2
        exit 1
    fi

    old_ifs="$IFS"
    IFS=","
    for item in $ONLY; do
        IFS="$old_ifs"
        case "$item" in
            codex | claude | pi)
                ;;
            "")
                echo "Empty agent name in --only list." >&2
                exit 1
                ;;
            *)
                echo "Unknown agent in --only list: $item" >&2
                usage >&2
                exit 1
                ;;
        esac

        if [ "$item" = "$agent" ]; then
            return 0
        fi

        IFS=","
    done
    IFS="$old_ifs"

    return 1
}

install_ai_instructions() {
    local tool_file="$1"
    local target="$2"
    local target_dir
    local tmp_file

    target_dir="$(dirname "$target")"
    mkdir -p "$target_dir"

    tmp_file="$(mktemp "${target}.tmp.XXXXXX")"
    {
        cat "$AI_DIR/instructions.md"
        printf '\n\n'
        cat "$AI_DIR/$tool_file"
    } > "$tmp_file"

    mv "$tmp_file" "$target"
}

install_ai_skills() {
    local target="$1"
    local marker
    local skill
    local skill_name
    local skills_dir
    local tmp_marker

    marker="$target/.dotfiles-managed"

    mkdir -p "$target"

    if [ -f "$marker" ]; then
        while IFS= read -r skill_name; do
            [ -n "$skill_name" ] || continue
            rm -rf "$target/$skill_name"
        done < "$marker"
    fi

    tmp_marker="$(mktemp "${marker}.tmp.XXXXXX")"
    for skills_dir in "$SKILLS_DIR" "$LOCAL_SKILLS_DIR"; do
        [ -d "$skills_dir" ] || continue

        for skill in "$skills_dir"/*; do
            [ -d "$skill" ] || continue
            skill_name="$(basename "$skill")"
            rm -rf "$target/$skill_name"
            cp -R "$skill" "$target/$skill_name"
            printf '%s\n' "$skill_name" >> "$tmp_marker"
        done
    done

    mv "$tmp_marker" "$marker"
}

clear_ai_skills() {
    local target="$1"
    local marker
    local skill_name

    marker="$target/.dotfiles-managed"

    [ -f "$marker" ] || return 0

    while IFS= read -r skill_name; do
        [ -n "$skill_name" ] || continue
        rm -rf "$target/$skill_name"
    done < "$marker"

    rm -f "$marker"
}

should_install() {
    local base_dir="$1"

    [ -d "$base_dir" ] || [ "$FORCE" -eq 1 ]
}

install_agent() {
    local name="$1"
    local base_dir="$2"
    local tool_file="$3"
    local instructions_target="$4"
    local skills_target="$5"

    if ! should_install "$base_dir"; then
        echo "Skipped $name because $base_dir does not exist. Use --force to create it."
        return
    fi

    install_ai_instructions "$tool_file" "$instructions_target"
    install_ai_skills "$skills_target"

    echo "Installed $name instructions to $instructions_target"
    echo "Installed $name skills to $skills_target"
}

install_instructions_target() {
    local name="$1"
    local base_dir="$2"
    local tool_file="$3"
    local instructions_target="$4"

    if ! should_install "$base_dir"; then
        echo "Skipped $name because $base_dir does not exist. Use --force to create it."
        return 1
    fi

    install_ai_instructions "$tool_file" "$instructions_target"
    echo "Installed $name instructions to $instructions_target"
}

install_skills_target() {
    local name="$1"
    local base_dir="$2"
    local skills_target="$3"

    if ! should_install "$base_dir"; then
        echo "Skipped $name skills because $base_dir does not exist. Use --force to create it."
        return
    fi

    install_ai_skills "$skills_target"
    echo "Installed $name skills to $skills_target"
}

install_pi() {
    local pi_base="$HOME/.pi/agent"
    local agents_base="$HOME/.agents"

    if ! install_instructions_target "Pi" "$pi_base" pi.md "$pi_base/AGENTS.md"; then
        return
    fi

    if should_install "$agents_base"; then
        install_ai_skills "$agents_base/skills"
        clear_ai_skills "$pi_base/skills"
        mkdir -p "$pi_base/skills"
        echo "Installed Pi skills to $agents_base/skills"
        echo "Created Pi-specific skills directory at $pi_base/skills"
        return
    fi

    install_ai_skills "$pi_base/skills"
    echo "Installed Pi skills to $pi_base/skills"
}

if is_selected codex; then
    install_agent "Codex" "$HOME/.codex" codex.md "$HOME/.codex/AGENTS.md" "$HOME/.codex/skills"
fi

if is_selected claude; then
    install_agent "Claude" "$HOME/.claude" claude.md "$HOME/.claude/CLAUDE.md" "$HOME/.claude/skills"
fi

if is_selected pi; then
    install_pi
fi

if [ "$ONLY_SET" -eq 0 ] && ! should_install "$HOME/.pi/agent"; then
    install_skills_target "Agent-standard" "$HOME/.agents" "$HOME/.agents/skills"
fi
