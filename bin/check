#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

echo "Checking shell files with zsh..."
zsh -n bootstrap.sh aliases/*.sh

echo "Checking shell files with bash..."
bash -n bootstrap.sh aliases/*.sh scripts/generate_prompt.sh

echo "Checking for stale PsySH references..."
if rg -n "psysh" README.md bootstrap.sh aliases scripts gitconfig work.example.sh local.example.sh >/dev/null; then
    echo "Found stale PsySH references."
    exit 1
fi

echo "Checking for path-dependent dotfiles references..."
if rg -n "~/dotfiles|scripts/php/bitbucket-pull-request.php|scripts/bitbucket_pr.sh" README.md bootstrap.sh aliases ai gitconfig work.example.sh >/dev/null; then
    echo "Found path-dependent or stale helper references."
    exit 1
fi

echo "All checks passed."
