#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

echo "Checking shell files with zsh..."
zsh -n bootstrap.sh aliases/*.sh

echo "Checking shell files with bash..."
bash -n bootstrap.sh aliases/*.sh scripts/generate_prompt.sh bin/setup-ai

echo "Checking for hardcoded dotfiles paths..."
if rg -n "~/dotfiles" README.md bootstrap.sh aliases ai bin/setup-ai gitconfig work.example.sh local.example.sh >/dev/null; then
    echo "Found hardcoded ~/dotfiles references."
    exit 1
fi

echo "All checks passed."
