[user]
    name = Semih ERDOGAN
    email = hasansemiherdogan@gmail.com
[github]
  user = semiherdogan
[init]
    defaultBranch = main
[core]
    editor = vi
    pager = delta
    autocrlf = input
[color]
    ui = auto
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    paging = never
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[push]
    autoSetupRemote = true
    default = current
[pull]
    rebase = false
[fetch]
    prune = true
[alias]
    st = status --short --branch
    aa = add -A
    ap = add -p
    cm = commit -m
    sw = switch
    d = diff
    pl = pull --ff-only
    ps = push
    lg = log --graph --decorate --oneline --abbrev-commit --all
    aliases = !git config -l | grep '^alias\\.' | cut -c 7-
