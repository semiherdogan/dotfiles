[user]
    name = Semih ERDOGAN
    email = hasansemiherdogan@gmail.com
[init]
    defaultBranch = main
[core]
    editor = vi
    pager = delta
    autocrlf = input
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    paging = never
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
[push]
    autoSetupRemote = true
    default = current
[fetch]
    prune = true
[alias]
    aa = add -A
    ap = add -p
    co = checkout
    sw = switch
    d = diff
    lg = log --graph --decorate --oneline --abbrev-commit --all
