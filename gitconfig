[user]
    name = Semih ERDOGAN
    email = hasansemiherdogan@gmail.com
[github]
  user = semiherdogan
[init]
    defaultBranch = main
[core]
    editor = vi
    autocrlf = input
[color]
    ui = auto
[push]
    autoSetupRemote = true
    default = current
[pull]
    rebase = false
[fetch]
    prune = true
[alias]
    st = status --short --branch
    aa = add -A
    ap = add -p
    cm = commit -m
    sw = switch
    d = diff
    pl = pull --ff-only
    ps = push
    lg = log --graph --decorate --oneline --abbrev-commit --all
    aliases = !git config -l | grep '^alias\\.' | cut -c 7-
